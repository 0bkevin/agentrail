    "demo:up": "tsx scripts/demo-up.ts",
    "demo:reset": "tsx scripts/reset-demo-state.ts",
    "sync:escrow-events": "tsx scripts/sync-escrow-events.ts",
    "worker:sync": "tsx services/sync-worker.ts",
    "service:provider-api": "tsx services/provider-api.ts",
    "service:device-sim": "tsx services/device-sim.ts",
    "service:proof-verifier": "tsx services/proof-verifier.ts",
    "service:human-solver": "tsx services/human-solver.ts"
  },
  "dependencies": {
    "@coinbase/wallet-sdk": "^4.3.7",
    "@fastify/cors": "^11.2.0",
    "@metamask/connect-evm": "^0.9.1",
    "@neondatabase/serverless": "^1.0.2",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
